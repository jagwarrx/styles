-- priority: -1

function togglePomodoro()
    local existing = js.window.document.getElementById("sb-pomodoro-root")
    if existing then
        existing.remove()
        return
    end

    local work_min = 25
    local short_break = 5
    local long_break = 15
    local long_break_after = 4

    local saved_top = clientStore.get("pm_pos_top") or "80px"
    local saved_left = clientStore.get("pm_pos_left") or "auto"
    local initial_right = "20px"
    if saved_left ~= "auto" then
        initial_right = "auto"
    end

    local container = js.window.document.createElement("div")
    container.id = "sb-pomodoro-root"
    container.style.cssText = "position:fixed;z-index:101;"
        .. "top:" .. saved_top .. ";left:" .. saved_left .. ";right:" .. initial_right .. ";"

    container.innerHTML = '<div class="pm-card" id="pm-card">'
        .. '<div class="pm-header" id="pm-handle">'
        .. '<span class="pm-header-label"><span>🍅</span><span>Pomodoro</span></span>'
        .. '<button class="pm-close" id="pm-close-btn">✕</button>'
        .. '</div>'
        .. '<div class="pm-body">'
        .. '<div class="pm-time" id="pm-time">25:00</div>'
        .. '<div class="pm-phase-label" id="pm-phase">Focus</div>'
        .. '<div class="pm-progress"><div class="pm-progress-bar" id="pm-progress" style="width:100%"></div></div>'
        .. '</div>'
        .. '<div class="pm-footer">'
        .. '<button class="pm-btn pm-btn-primary" id="pm-start">Start</button>'
        .. '<button class="pm-btn" id="pm-reset">Reset</button>'
        .. '<button class="pm-btn" id="pm-skip">Skip ▶</button>'
        .. '<span class="pm-sessions" id="pm-sessions">0 / 4</span>'
        .. '</div>'
        .. '</div>'

    js.window.document.body.appendChild(container)

    local scriptEl = js.window.document.createElement("script")
    scriptEl.textContent = '(function(){'
        .. 'var WORK=' .. work_min .. '*60,SHORT=' .. short_break .. '*60,LONG=' .. long_break .. '*60;'
        .. 'var LONG_AFTER=' .. long_break_after .. ';'
        .. 'var root=document.getElementById("sb-pomodoro-root");'
        .. 'var card=document.getElementById("pm-card");'
        .. 'var timeEl=document.getElementById("pm-time");'
        .. 'var phaseEl=document.getElementById("pm-phase");'
        .. 'var progressEl=document.getElementById("pm-progress");'
        .. 'var startBtn=document.getElementById("pm-start");'
        .. 'var resetBtn=document.getElementById("pm-reset");'
        .. 'var skipBtn=document.getElementById("pm-skip");'
        .. 'var sessionsEl=document.getElementById("pm-sessions");'
        .. 'var timer=null,remaining=WORK,total=WORK,sessions=0,isBreak=false,running=false;'
        .. 'function fmt(s){var m=Math.floor(s/60);var sec=s%60;return String(m).padStart(2,"0")+":"+String(sec).padStart(2,"0")}'
        .. 'function render(){'
        .. 'timeEl.textContent=fmt(remaining);'
        .. 'progressEl.style.width=Math.round((remaining/total)*100)+"%";'
        .. 'sessionsEl.textContent=sessions+" / "+LONG_AFTER;'
        .. 'card.classList.toggle("is-break",isBreak);'
        .. 'card.classList.toggle("is-running",running&&!isBreak);'
        .. 'startBtn.textContent=running?"Pause":"Start";'
        .. '}'
        .. 'function tick(){'
        .. 'if(remaining<=0){clearInterval(timer);timer=null;running=false;'
        .. 'try{new Audio("data:audio/wav;base64,UklGRnoGAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQoGAACBhYqFbF1fdJivrJBhNjVgodDbsGczGjlzl7m2bUEhPnCaw7Z0RCQ7aZS3sXlHKDtokbOseUosPGmRsapzRyg8apS2rXFBIT5wnMO4ckAePXGfx7t0QBw8caDKvnVBHDxxocu+dD8aOnKjz8N2Pxg4cqbTx3g+Fjdxp9XJeT0VNnGn1sl5PRU2cafWynk9FDVxqNfLej0UNXGp2Mt6PBM0cqra").play()}catch(e){}'
        .. 'if(!isBreak){sessions++;isBreak=true;'
        .. 'if(sessions%LONG_AFTER===0){total=LONG;remaining=LONG;phaseEl.textContent="Long Break"}'
        .. 'else{total=SHORT;remaining=SHORT;phaseEl.textContent="Short Break"}'
        .. '}else{isBreak=false;total=WORK;remaining=WORK;phaseEl.textContent="Focus"}'
        .. 'render();return}'
        .. 'remaining--;render();'
        .. '}'
        .. 'startBtn.onclick=function(){'
        .. 'if(running){clearInterval(timer);timer=null;running=false}'
        .. 'else{running=true;timer=setInterval(tick,1000)}'
        .. 'render();'
        .. '};'
        .. 'resetBtn.onclick=function(){'
        .. 'clearInterval(timer);timer=null;running=false;'
        .. 'if(isBreak){remaining=total}else{remaining=WORK;total=WORK}'
        .. 'render();'
        .. '};'
        .. 'skipBtn.onclick=function(){'
        .. 'clearInterval(timer);timer=null;running=false;remaining=0;'
        .. 'if(!isBreak){sessions++;isBreak=true;'
        .. 'if(sessions%LONG_AFTER===0){total=LONG;remaining=LONG;phaseEl.textContent="Long Break"}'
        .. 'else{total=SHORT;remaining=SHORT;phaseEl.textContent="Short Break"}'
        .. '}else{isBreak=false;total=WORK;remaining=WORK;phaseEl.textContent="Focus"}'
        .. 'render();'
        .. '};'
        .. 'document.getElementById("pm-close-btn").onclick=function(e){e.stopPropagation();'
        .. 'clearInterval(timer);root.remove()};'
        .. 'var SNAP=15,TOP_OFFSET=60;'
        .. 'document.getElementById("pm-handle").onpointerdown=function(e){'
        .. 'if(e.target.closest("button"))return;'
        .. 'document.body.classList.add("sb-dragging-active");'
        .. 'var sX=e.clientX-root.offsetLeft,sY=e.clientY-root.offsetTop;'
        .. 'function move(m){'
        .. 'var nL=m.clientX-sX,nT=m.clientY-sY;'
        .. 'var w=root.offsetWidth,h=root.offsetHeight;'
        .. 'if(nL<SNAP)nL=0;if(nT<TOP_OFFSET+SNAP)nT=TOP_OFFSET;'
        .. 'if(nL+w>window.innerWidth-SNAP)nL=window.innerWidth-w;'
        .. 'if(nT+h>window.innerHeight-SNAP)nT=window.innerHeight-h;'
        .. 'root.style.left=Math.max(0,Math.min(nL,window.innerWidth-w))+"px";'
        .. 'root.style.top=Math.max(TOP_OFFSET,Math.min(nT,window.innerHeight-h))+"px";'
        .. 'root.style.right="auto";'
        .. '}'
        .. 'function up(){'
        .. 'document.body.classList.remove("sb-dragging-active");'
        .. 'window.removeEventListener("pointermove",move);'
        .. 'window.__pm_pos={top:root.style.top,left:root.style.left};'
        .. '}'
        .. 'window.addEventListener("pointermove",move);'
        .. 'window.addEventListener("pointerup",up,{once:true});'
        .. '};'
        .. 'render();'
        .. '})();'

    container.appendChild(scriptEl)
end

function pomoWidget()
    return widget.new {
        html = '<span id="pomo-badge" style="display:inline-block;font-size:14px;font-weight:500;font-variant-numeric:tabular-nums;padding:2px 8px 2px 42px;border-radius:6px;cursor:pointer;vertical-align:middle;line-height:1.5;user-select:none;border:1.5px solid #e8a0a0;background:#fef2f2;color:#b91c1c;font-family:system-ui,sans-serif;white-space:nowrap;text-align:center;"><span id="pomo-inline-txt">25:00</span></span>';
        display = "inline";
        events = {
            click = function()
                local scriptEl = js.window.document.createElement("script")
                scriptEl.textContent = '(function(){'
                    .. 'var el=document.getElementById("pomo-badge");'
                    .. 'var txt=document.getElementById("pomo-inline-txt");'
                    .. 'if(!el||!txt)return;'
                    .. 'if(!window._pomo){window._pomo={r:25*60,t:25*60,s:0,brk:false,run:false,tmr:null}}'
                    .. 'var p=window._pomo;'
                    .. 'function fmt(s){var m=Math.floor(s/60);var sec=s%60;return String(m).padStart(2,"0")+":"+String(sec).padStart(2,"0")}'
                    .. 'function render(){'
                    .. 'var txt=document.getElementById("pomo-inline-txt");'
                    .. 'var el=document.getElementById("pomo-badge");'
                    .. 'if(!el||!txt)return;'
                    .. 'txt.textContent=fmt(p.r);'
                    .. 'if(p.brk){'
                    .. 'el.style.background="#f0fdf4";el.style.borderColor="#a3d9a5";el.style.color="#15803d"}'
                    .. 'else if(p.run){'
                    .. 'el.style.background="#fef2f2";el.style.borderColor="#e8a0a0";el.style.color="#b91c1c"}'
                    .. 'else{'
                    .. 'el.style.background="#f9fafb";el.style.borderColor="#d1d5db";el.style.color="#6b7280"}'
                    .. '}'
                    .. 'function tick(){'
                    .. 'if(p.r<=0){clearInterval(p.tmr);p.tmr=null;p.run=false;'
                    .. 'try{new Audio("data:audio/wav;base64,UklGRnoGAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YQoGAACBhYqFbF1fdJivrJBhNjVgodDbsGczGjlzl7m2bUEhPnCaw7Z0RCQ7aZS3sXlHKDtokbOseUosPGmRsapzRyg8apS2rXFBIT5wnMO4ckAePXGfx7t0QBw8caDKvnVBHDxxocu+dD8aOnKjz8N2Pxg4cqbTx3g+Fjdxp9XJeT0VNnGn1sl5PRU2cafWynk9FDVxqNfLej0UNXGp2Mt6PBM0cqra").play()}catch(e){}'
                    .. 'if(!p.brk){p.s++;p.brk=true;if(p.s%4===0){p.t=15*60;p.r=15*60}else{p.t=5*60;p.r=5*60}}'
                    .. 'else{p.brk=false;p.t=25*60;p.r=25*60}'
                    .. 'render();return}'
                    .. 'p.r--;render();'
                    .. '}'
                    .. 'if(p.run){clearInterval(p.tmr);p.tmr=null;p.run=false}'
                    .. 'else{p.run=true;p.tmr=setInterval(tick,1000)}'
                    .. 'render();'
                    .. '})();'

                js.window.document.body.appendChild(scriptEl)
            end
        }
    }
end

js.window.addEventListener("beforeunload", function()
    local pos = js.window.__pm_pos
    if pos then
        clientStore.set("pm_pos_top", tostring(pos.top))
        clientStore.set("pm_pos_left", tostring(pos.left))
    end
end)

command.define {
    name = "Pomodoro: Start",
    run = function() togglePomodoro() end
}

command.define {
    name = "Pomodoro: Inline",
    run = function()
        editor.insertAtCursor("${pomoWidget()}")
    end
}
