html[data-theme="dark"] #sb-pomodoro-root {
    --pm-bg: #2b2b2d;
    --pm-border: rgba(255,255,255,0.2);
    --pm-text: #e5e5e5;
    --pm-dim: #777;
    --pm-accent: #e74c3c;
    --pm-accent-break: #27ae60;
    --pm-hover: rgba(255,255,255,0.1);
    --pm-progress-bg: rgba(255,255,255,0.08);
}

html[data-theme="light"] #sb-pomodoro-root {
    --pm-bg: #fafafa;
    --pm-border: rgba(0,0,0,0.18);
    --pm-text: #1a1a1a;
    --pm-dim: #999;
    --pm-accent: #e74c3c;
    --pm-accent-break: #27ae60;
    --pm-hover: rgba(0,0,0,0.06);
    --pm-progress-bg: rgba(0,0,0,0.06);
}

.pm-card {
    background: var(--pm-bg);
    color: var(--pm-text);
    border-radius: 14px;
    border: 2px solid var(--pm-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-width: 220px;
}

.pm-card.is-break { border-color: var(--pm-accent-break); }
.pm-card.is-running { border-color: var(--pm-accent); }

.pm-header {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    cursor: grab;
    position: relative;
    gap: 6px;
}

.pm-header-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--pm-text);
    display: flex;
    align-items: center;
    gap: 5px;
}

.pm-close {
    position: absolute;
    right: 10px;
    background: transparent;
    color: var(--pm-dim);
    border: none;
    border-radius: 4px;
    padding: 0 3px;
    cursor: pointer;
    font-size: 0.8em;
    line-height: 1;
    opacity: 0.4;
}
.pm-close:hover { opacity: 1; background: oklch(0.65 0.2 30); color: white; }

.pm-body {
    padding: 12px 16px;
    text-align: center;
    border-top: 1px solid var(--pm-border);
    border-bottom: 1px solid var(--pm-border);
}

.pm-time {
    font-size: 36px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.5px;
    line-height: 1.2;
}

.pm-phase-label {
    font-size: 11px;
    color: var(--pm-dim);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 2px;
}

.pm-progress {
    width: 100%;
    height: 3px;
    background: var(--pm-progress-bg);
    margin-top: 8px;
    border-radius: 2px;
    overflow: hidden;
}

.pm-progress-bar {
    height: 100%;
    background: var(--pm-accent);
    border-radius: 2px;
    transition: width 1s linear;
}

.pm-card.is-break .pm-progress-bar { background: var(--pm-accent-break); }

.pm-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 10px;
    gap: 6px;
}

.pm-btn {
    background: transparent;
    color: var(--pm-dim);
    border: 1px solid var(--pm-border);
    border-radius: 6px;
    padding: 3px 10px;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
}
.pm-btn:hover { color: var(--pm-text); background: var(--pm-hover); }

.pm-btn-primary {
    background: var(--pm-accent);
    color: white;
    border-color: var(--pm-accent);
}
.pm-btn-primary:hover { opacity: 0.9; background: var(--pm-accent); color: white; }

.pm-sessions {
    font-size: 11px;
    color: var(--pm-dim);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
}
